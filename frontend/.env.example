# ── API Backend ──
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Auth Mode ──
# "mock" = built-in mock login (default, no external IdP needed)
# "keycloak" = NextAuth + Keycloak OIDC
NEXT_PUBLIC_AUTH_MODE=mock

# ── NextAuth (required when AUTH_MODE=keycloak) ──
# Generate with: npx auth secret
AUTH_SECRET=

# ── Keycloak OIDC (required when AUTH_MODE=keycloak) ──
AUTH_KEYCLOAK_ID=your-client-id
AUTH_KEYCLOAK_SECRET=your-client-secret
AUTH_KEYCLOAK_ISSUER=https://your-keycloak-server/realms/your-realm
